[vault]
# Use forward slashes in paths (e.g. C:/Users/me/vault): TOML treats
# backslashes as escape characters.
input_dir = "vault"
output_dir = "vault.kindle"

exclude = [".obsidian/*", "templates/*"]

[image]
max_width = 1000
grayscale = true
jpeg_quality = 70
timeout = 15.0
retries = 1
max_bytes = 8388608
